# Queens Connect – Cloud Functions env (copy to .env, never commit .env)
# For local emulator you can use .env or firebase functions:config:set

# WhatsApp Cloud API webhook – verify token sent by Meta
WEBHOOK_WHATSAPP_SECRET=your_webhook_verify_token

# Ikhokha – webhook signature / secret for incoming payment callbacks
IKHOKHA_WEBHOOK_SECRET=your_ikhokha_webhook_secret
IKHOKHA_API_KEY=your_ikhokha_api_key
IKHOKHA_API_SECRET=your_ikhokha_api_secret

# Optional: base URL for payment links (e.g. https://pay.ikhokha.com)
# IKHOKHA_BASE_URL=

# Didit.me – KYC verification (createVerificationSession / checkVerificationResult)
DIDIT_API_KEY=your_didit_api_key
DIDIT_API_ID=your_didit_api_id
DIDIT_WORKFLOW_ID=your_didit_workflow_id
