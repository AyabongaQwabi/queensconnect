{
  "name": "functions",
  "description": "Queens Connect – Firebase Cloud Functions (WhatsApp webhook, orchestrator, Ikhokha)",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "seed": "node scripts/seed.js",
    "seed:emulator": "FIRESTORE_EMULATOR_HOST=127.0.0.1:8086 node scripts/seed.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
