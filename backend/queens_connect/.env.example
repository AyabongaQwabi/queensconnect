# Queens Connect – copy to .env and fill in (do not commit .env)

# Gemini / Google AI (required for agents)
GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=

# Optional: override default model (default: gemini-3.1-pro-preview)
# MODEL=gemini-2.5-pro

# Firebase – only needed if different from defaults
# FIREBASE_PROJECT_ID=queens-connect-2c94d

# Firestore emulator: set when running against local emulator (e.g. firebase emulators:start)
# Use the port from firebase.json → emulators.firestore.port (functions use 8086)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8086

# Optional: Firebase Auth ID token when calling Cloud Functions that require auth
# Get via Firebase Auth (e.g. getIdToken()). Leave unset for Admin SDK / emulator.
# FIREBASE_ID_TOKEN=

# Optional: Cloud Functions base URL (default points to local emulator)
# FIREBASE_FUNCTIONS_URL=http://127.0.0.1:5002/queens-connect-2c94d/us-central1

# SerpAPI for Google Search agent (optional)
# SERPAPI_KEY=

# Yoco – payment links for loan unlock fees (sk_test_... or sk_live_...)
YOCO_SECRET_KEY=

# Didit.me – KYC verification (used by lending/registration tools if calling from backend)
DIDIT_API_KEY=
DIDIT_API_ID=
DIDIT_WORKFLOW_ID=
