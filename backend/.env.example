# Queens Connect backend – copy to .env and fill in (do not commit .env)

# Gemini / Google AI (required for orchestrators: moderation, gatekeeper, core)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=

# Groq (required for sub-agents: Llama via LiteLLM)
GROQ_API_KEY=

# xAI (required for Grok kasi-voice rewrite)
XAI_API_KEY=

# Optional: override models
# MODEL=gemini-2.5-flash
# GROQ_MODEL=groq/llama-3.3-70b-versatile
# GROK_MODEL=xai/grok-4-1-fast-reasoning

# Firestore emulator (when using local emulator)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8086

# iKhoka Pay Link (unlock loan request fee)
# IKHOKHA_APPLICATION_ID=
# IKHOKHA_APPLICATION_KEY=
# Base URL for callbacks (e.g. https://your-api.example.com)
# LENDING_BASE_URL=

# Twilio WhatsApp (incoming webhook + outbound notifications)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
# Notify borrower when a lender accepts their loan (Twilio Content SID for approved template, e.g. "A lender accepted your loan of {{2}} for {{1}}.")
# TWILIO_LOAN_MATCH_CONTENT_SID=
