# Queens Connect backend – copy to .env and fill in (do not commit .env)

# Gemini / Google AI (required for orchestrators: moderation, gatekeeper, core)
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Or: GEMINI_API_KEY=

# Groq (required for sub-agents: Llama via LiteLLM)
GROQ_API_KEY=

# xAI (required for Grok kasi-voice rewrite)
XAI_API_KEY=

# Optional: override models
# MODEL=gemini-2.5-flash
# GROQ_MODEL=groq/llama-3.3-70b-versatile
# GROK_MODEL=xai/grok-4-1-fast-reasoning

# Firestore emulator (when using local emulator)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8086

# iKhoka Pay Link (unlock loan request fee)
# IKHOKHA_APPLICATION_ID=
# IKHOKHA_APPLICATION_KEY=
# Base URL for callbacks (e.g. https://your-api.example.com)
# LENDING_BASE_URL=

# Twilio WhatsApp (webhook + interactive Content Templates)
# Get from https://console.twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# From: use your WhatsApp sender (e.g. whatsapp:+27...) or Messaging Service SID (MG...) when using Content templates
# TWILIO_WHATSAPP_FROM=
# Optional: Messaging Service SID when sending with Content templates (MG...)
# TWILIO_MESSAGING_SERVICE_SID=

# Twilio Content Template SIDs (HX...) – set after running scripts/create_whatsapp_content_templates.py
# TWILIO_CONTENT_ONBOARDING_INTENT=
# TWILIO_CONTENT_ONBOARDING_OPTIONAL_DETAILS=
# TWILIO_CONTENT_ONBOARDING_GENDER=
# TWILIO_CONTENT_MAIN_MENU=
# TWILIO_CONTENT_LOANS_MENU=
# TWILIO_CONTENT_STOKVEL_MENU=
